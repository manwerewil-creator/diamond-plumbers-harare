# ─────────────────────────────────────────────────────────────────────────────
# Diamond Plumbers — environment variables
# Copy this file to `.env.local` and fill in real values.
# EVERY integration below degrades gracefully: if the key is missing, the quote
# form still works in "demo mode" (logs the lead to the server console) so you
# can deploy and test before wiring up the backends.
# ─────────────────────────────────────────────────────────────────────────────

# --- Public site config (safe to expose to the browser) ----------------------
NEXT_PUBLIC_SITE_URL=https://diamondplumbers.co.zw

# Phone / WhatsApp — REPLACE_WITH_REAL_NUMBERS (E.164, e.g. +263772123456)
NEXT_PUBLIC_PHONE=+263772000000
NEXT_PUBLIC_WHATSAPP=263772000000

# --- Supabase (leads, services, case_studies, testimonials) ------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. NEVER expose. Used by the /api/lead route to insert leads.
SUPABASE_SERVICE_ROLE_KEY=

# --- Email notifications (Resend) --------------------------------------------
RESEND_API_KEY=
LEAD_NOTIFY_EMAIL=leads@diamondplumbers.co.zw
LEAD_FROM_EMAIL=Diamond Plumbers <quotes@diamondplumbers.co.zw>

# --- WhatsApp Business API (Twilio) ------------------------------------------
# On-call technician notifications. Optional — falls back to console log.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TECHNICIAN_WHATSAPP=whatsapp:+263772000000

# --- Maps (optional) ---------------------------------------------------------
# If unset, the site renders a fast custom SVG service-area map instead.
NEXT_PUBLIC_MAPBOX_TOKEN=

# --- Analytics (optional) ----------------------------------------------------
# Plausible. If unset, no analytics script is loaded.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
